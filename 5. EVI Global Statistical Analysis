    "city_raw": [extract_city(f) for f in tif_files]
})

def normalize(name):
    return re.sub(r"[\s\-\.\(\)]", "", str(name)).lower()

lag_df["city_key"] = lag_df["city_raw"].apply(normalize)
koppen_df["city_key_norm"] = koppen_df["city_key"].apply(normalize)

# merge：贴上 koppen
