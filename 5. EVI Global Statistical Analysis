# ============================================================
# 5) 两两 KS 检验 + 多重比较校正（仅 n>=MIN_N_PER_ZONE 的子类）
# ============================================================
eligible = order_df.loc[order_df["n"] >= MIN_N_PER_ZONE, "koppen"].tolist()
print(f"\nEligible subclasses for KS (n>={MIN_N_PER_ZONE}): {eligible}")

pairs = list(itertools.combinations(eligible, 2))
ks_rows = []

for a, b in pairs:
    xa = df_valid.loc[df_valid["koppen"] == a, TEST_METRIC].values
    xb = df_valid.loc[df_valid["koppen"] == b, TEST_METRIC].values
    # 这里 xa/xb 是“城市层面样本”，与审稿人强调的“类别样本数小”一致
    ks = ks_2samp(xa, xb, alternative=KS_ALTERNATIVE, mode="auto")
    ks_rows.append({
        "koppen_a": a, "koppen_b": b,
        "n_a": len(xa), "n_b": len(xb),
        "ks_stat": float(ks.statistic),
        "p_raw": float(ks.pvalue)
    })

ks_df = pd.DataFrame(ks_rows)

# ---- 多重比较校正：Holm / Dunn–Šidák / Bonferroni / none
def p_adjust(pvals, method="holm"):
    pvals = np.asarray(pvals, dtype=float)
    out = np.full_like(pvals, np.nan, dtype=float)
    idx = np.where(np.isfinite(pvals))[0]
    m = len(idx)
    if m == 0:
        return out

    p = pvals[idx]
    method = (method or "none").lower()

    if method == "none":
        out[idx] = p
        return out

    if method == "bonferroni":
        out[idx] = np.minimum(p * m, 1.0)
        return out

    if method in ["sidak", "dunn-sidak", "dunnsidak", "dunn–sidak"]:
        out[idx] = np.minimum(1.0 - (1.0 - p) ** m, 1.0)
        return out

    if method == "holm":
        # Holm step-down:
        # sort p ascending: p_(1)<=...<=p_(m)
        # adj p_(i) = max_{j<=i} min( (m-j+1)*p_(j), 1 )
        order = np.argsort(p)
        p_sorted = p[order]
        adj_sorted = np.empty_like(p_sorted)

        running_max = 0.0
        for i in range(m):
            factor = (m - i)
            val = min(p_sorted[i] * factor, 1.0)
            running_max = max(running_max, val)
            adj_sorted[i] = running_max

        # place back
        adj = np.empty_like(p)
        adj[order] = adj_sorted
        out[idx] = adj
        return out

    raise ValueError(f"Unknown method: {method}")

ks_df["p_adj"] = p_adjust(ks_df["p_raw"].values, method=P_ADJUST)

ks_df_sorted = ks_df.sort_values(["p_adj","p_raw"], ascending=True).reset_index(drop=True)
ks_df_sorted.to_csv(OUT_KS, index=False)
