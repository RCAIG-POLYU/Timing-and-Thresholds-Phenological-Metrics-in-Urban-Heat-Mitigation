    how="left"
)

print("\n=== 匹配后的城市气候表（前20行）===")
print(merged[["city_raw","koppen"]].head(20))

# ============================================================
# 2) 读 tif -> 每城市一个值（lag_mean/lag_median/lag_abs_mean）
#    这里“每城市”作为统计样本，与审稿人讨论的“类别样本数n”一致
# ============================================================
df = merged.copy()

lag_means, lag_medians, lag_abs = [], [], []

for _, row in df.iterrows():
    tif_path = os.path.join(LAG_DIR, row["file"])
    try:
        with rasterio.open(tif_path) as ds:
            arr = ds.read(1, masked=True).astype("float32")  # 单波段
            vals = arr.compressed()
            vals = vals[np.isfinite(vals)]
            if len(vals) == 0:
                lag_means.append(np.nan)
                lag_medians.append(np.nan)
                lag_abs.append(np.nan)
            else:
                lag_means.append(float(np.mean(vals)))
                lag_medians.append(float(np.median(vals)))
                lag_abs.append(float(np.mean(np.abs(vals))))
    except Exception as e:
        lag_means.append(np.nan)
        lag_medians.append(np.nan)
        lag_abs.append(np.nan)

df["lag_mean"] = lag_means
df["lag_median"] = lag_medians
df["lag_abs_mean"] = lag_abs

# 清理：必须有koppen且指标非nan
df_valid = df.dropna(subset=["koppen", TEST_METRIC]).copy()

# 保存城市表（方便复现与审稿核对）
