# CatBoost training params (GPU + early stop)
CB_PARAMS_GPU = dict(
    iterations=8000,
    depth=8,
    learning_rate=0.08,
    l2_leaf_reg=3.0,
    loss_function="RMSE",
    eval_metric="RMSE",
    random_seed=RANDOM_SEED,
    task_type="GPU",
    devices="0",
    od_type="Iter",
    od_wait=200,
    verbose=200,
)

CB_PARAMS_CPU_FALLBACK = dict(
    iterations=3000,
    depth=8,
    learning_rate=0.05,
    l2_leaf_reg=3.0,
    loss_function="RMSE",
    eval_metric="RMSE",
    random_seed=RANDOM_SEED,
    od_type="Iter",
    od_wait=200,
    verbose=200,
)

# SHAP computation budget per fold (controls runtime)
# 50k–150k is usually enough for stable mean(|SHAP|)
SHAP_MAX_SAMPLES_PER_FOLD = 120_000
SHAP_TOPK = 20

# --------------------------
# 1) LOAD DATA
# --------------------------
npz = np.load(NPZ_PATH, allow_pickle=True)
X_raw = npz["X"].astype(np.float32)
y_raw = npz["y"].astype(np.float32)
channels_raw = npz["channels"].astype(object).tolist()

print(f"Loaded: X={X_raw.shape}, y={y_raw.shape}, n_channels={len(channels_raw)}")

# y finite mask
mask = np.isfinite(y_raw)
X_raw = X_raw[mask]
y = y_raw[mask]

# identify city column
assert CITY_COL in channels_raw, f"Missing {CITY_COL} in channels"
city_idx = channels_raw.index(CITY_COL)
groups_city = X_raw[:, city_idx].astype(np.int32)

# Build keep features (exclude CITY_ID from features; you already drop it in modeling)
keep_idx = []
dropped = []
for i, ch in enumerate(channels_raw):
    if ch == CITY_COL:
        dropped.append(ch); continue
    if ch.upper().startswith("LST."):  # safety
        dropped.append(ch); continue
    if ch in DROP_LIST:
        dropped.append(ch); continue
    keep_idx.append(i)

X = X_raw[:, keep_idx]
features = [channels_raw[i] for i in keep_idx]

print(f"After mask: X={X.shape}, y={y.shape}")
print(f"Features kept: {len(features)}")
print(f"Features dropped: {len(dropped)} (first 10): {dropped[:10]}")

# --------------------------
# 2) HELPERS
# --------------------------
def eval_metrics(y_true, y_pred):
    rmse = float(mean_squared_error(y_true, y_pred) ** 0.5)
    mae  = float(mean_absolute_error(y_true, y_pred))
    r2   = float(r2_score(y_true, y_pred))
    return {"rmse": rmse, "mae": mae, "r2": r2}

def try_train_catboost(X_tr, y_tr, X_te, y_te, feature_names):
    train_pool = Pool(X_tr, y_tr, feature_names=feature_names)
    test_pool  = Pool(X_te, y_te, feature_names=feature_names)
    # try GPU first
    try:
        model = CatBoostRegressor(**CB_PARAMS_GPU)
        model.fit(train_pool, eval_set=test_pool, use_best_model=True)
        used_gpu = True
    except Exception as e:
        print("[WARN] GPU training failed -> CPU fallback:", repr(e))
        model = CatBoostRegressor(**CB_PARAMS_CPU_FALLBACK)
        model.fit(train_pool, eval_set=test_pool, use_best_model=True)
        used_gpu = False
    return model, used_gpu

def fast_shap_mean_abs(model, X_te, feature_names, max_samples=120_000, seed=42):
    """
    Compute mean(|SHAP|) on a subsample of test set.
    CatBoost returns matrix (n, n_features+1) with last column = expected_value.
    """
    n = X_te.shape[0]
    if n == 0:
        return np.zeros((len(feature_names),), dtype=np.float64), 0

    rng = np.random.default_rng(seed)
    if n > max_samples:
        idx = rng.choice(n, size=max_samples, replace=False)
        Xs = X_te[idx]
    else:
        Xs = X_te

    pool = Pool(Xs, feature_names=feature_names)
    shap = model.get_feature_importance(pool, type="ShapValues")  # (m, p+1)
    shap = np.asarray(shap)
    shap_feat = shap[:, :-1]  # drop expected value
    mean_abs = np.mean(np.abs(shap_feat), axis=0).astype(np.float64)
    return mean_abs, Xs.shape[0]

def rankdata_desc(values):
    # rank 1 = largest
    order = np.argsort(-values)
    ranks = np.empty_like(order)
    ranks[order] = np.arange(1, len(values)+1)
    return ranks

def spearman_rho(a, b):
    # Spearman via rank correlation (no scipy dependency)
    ra = rankdata_desc(a).astype(np.float64)
    rb = rankdata_desc(b).astype(np.float64)
    ra -= ra.mean(); rb -= rb.mean()
    denom = np.sqrt(np.sum(ra**2) * np.sum(rb**2))
    if denom == 0:
        return np.nan
    return float(np.sum(ra*rb) / denom)

# --------------------------
# 3) CV LOOP (City-GroupKFold)
# --------------------------
gkf = GroupKFold(n_splits=N_SPLITS)

fold_metrics = []
fold_shap = []         # list of mean_abs shap arrays
fold_topk = []         # list of topk feature names per fold
fold_used_gpu = []

stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
