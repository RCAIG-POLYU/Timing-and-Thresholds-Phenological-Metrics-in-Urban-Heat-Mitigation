# 95% CI across folds (t approx ~ use 1.96 for simplicity; folds=5 small but ok for rebuttal)
ci95 = 1.96 * std_imp / max(1.0, math.sqrt(N_SPLITS))

# TopK frequency
topk_freq = {f: 0 for f in features}
for top_list in fold_topk:
    for f in top_list:
        topk_freq[f] += 1
topk_freq = {k: v/N_SPLITS for k, v in topk_freq.items()}  # frequency in [0,1]

# Rank correlation across fold pairs
pair_rhos = []
for i, j in combinations(range(N_SPLITS), 2):
    rho = spearman_rho(S[i], S[j])
    pair_rhos.append(rho)
rho_mean = float(np.nanmean(pair_rhos))
rho_std  = float(np.nanstd(pair_rhos, ddof=1)) if len(pair_rhos) > 1 else 0.0

# Build summary table
summary_df = pd.DataFrame({
    "feature": features,
    "shap_mean_abs_mean": mean_imp,
    "shap_mean_abs_std": std_imp,
    "shap_mean_abs_ci95": ci95,
    "topk_freq": [topk_freq[f] for f in features],
})
summary_df = summary_df.sort_values("shap_mean_abs_mean", ascending=False)
summary_df.to_csv(os.path.join(run_dir, "cv_shap_summary.csv"), index=False)

