def sample_indices(rng, n, k):
    if k <= 0 or k >= n:
        return np.arange(n, dtype=np.int64)
    return rng.choice(n, size=k, replace=False)

def perturb_X_gaussian(Xbase, cols, sigma_rel, rng):
    """
    Xbase: (n,d)
    cols: list of feature indices to perturb
    sigma_rel: scalar, noise = sigma_rel * std(feature)
    returns Xpert (copy)
    """
    if sigma_rel <= 0:
        return Xbase  # no copy for speed
    Xp = Xbase.copy()
    for c in cols:
        s = sigma_rel * feat_std[c]
        noise = rng.normal(0.0, s, size=Xp.shape[0]).astype(np.float32)
        Xp[:, c] = (Xp[:, c] + noise).astype(np.float32)
    return Xp

def mean_ci95(arr):
    arr = np.asarray(arr, dtype=float)
    m = float(np.mean(arr))
    if arr.size <= 1:
        return m, 0.0
    se = float(np.std(arr, ddof=1) / np.sqrt(arr.size))
    return m, 1.96 * se

