fold_models = []

stamp = datetime.now().strftime("%Y%m%d_%H%M%S")
run_tag = f"perturb_citycv_{stamp}"
t0 = time.time()

for fold, (tr_idx, te_idx) in enumerate(gkf.split(X, y, groups=city_id), 1):
    # Train/val split within training cities (simple holdout for early stopping)
    # (fast & OK; if you want, you can do another Group split inside training)
    Xtr_full, ytr_full = X[tr_idx], y[tr_idx]
    Xte_full, yte_full = X[te_idx], y[te_idx]

    # Make a small validation set from training for early stopping
    # (random sample inside training; doesn't leak holdout cities)
    ntr = Xtr_full.shape[0]
    val_n = min(200000, max(50000, int(0.1 * ntr)))  # adaptive
    val_idx_local = sample_indices(rng, ntr, val_n)
    tr_mask = np.ones(ntr, dtype=bool)
    tr_mask[val_idx_local] = False

    Xtr, ytr = Xtr_full[tr_mask], ytr_full[tr_mask]
    Xva, yva = Xtr_full[val_idx_local], ytr_full[val_idx_local]

    model, used_gpu = train_catboost(Xtr, ytr, Xva, yva, channels_final)

    # Sample test points for speed
    nte = Xte_full.shape[0]
    take = min(N_PER_FOLD, nte)
    take_idx = sample_indices(rng, nte, take)
    Xte = Xte_full[take_idx]
    yte = yte_full[take_idx]

    # Baseline
    yhat0 = model.predict(Xte)
    rmse0, mae0, r20 = evaluate(yte, yhat0)

    print(f"[Fold {fold}/{K}] baseline RMSE={rmse0:.3f} MAE={mae0:.3f} R2={r20:.3f} | used_gpu={used_gpu} | test_n={take}")

    # Perturb for each sigma, repeated R times
    for sigma in SIGMA_LIST:
        deltas = []
        rmses  = []
        for rep in range(R):
            rrng = np.random.default_rng(RANDOM_SEED + fold*1000 + rep*10 + int(sigma*100))
            Xp = perturb_X_gaussian(Xte, perturb_cols, sigma_rel=sigma, rng=rrng)
            yhat = model.predict(Xp)
            rmse, _, _ = evaluate(yte, yhat)
            rmses.append(rmse)
            deltas.append(rmse - rmse0)

        d_mean, d_ci = mean_ci95(deltas)
        r_mean, r_ci = mean_ci95(rmses)

        rows.append({
