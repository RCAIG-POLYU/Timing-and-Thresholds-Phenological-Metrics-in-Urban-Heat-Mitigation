def permute_naive_delta_rmse(model, Xtest, ytest, j, repeats=3, seed=0):
    rng = np.random.default_rng(seed)
    deltas = []
    for r in range(repeats):
        Xp = Xtest.copy()
        rng.shuffle(Xp[:, j])  # in-place permutation of column
        p = model.predict(Xp)
        rmse = mean_squared_error(ytest, p) ** 0.5
        deltas.append(rmse - rmse0)
    return float(np.mean(deltas)), float(np.std(deltas))

def ridge_fit_residual(X_other, x_target, alpha=1.0):
    """
    Fit ridge: x ≈ X_other w + b, return residuals e = x - (Xw+b)
    Closed-form, fast, stable.
    """
    Xo = X_other.astype(np.float64)
    xt = x_target.astype(np.float64)

    # add intercept
    ones = np.ones((Xo.shape[0], 1), dtype=np.float64)
    A = np.hstack([Xo, ones])  # (n, p+1)

    # ridge on weights only, not intercept
    p = A.shape[1]
    I = np.eye(p, dtype=np.float64)
    I[-1, -1] = 0.0  # no penalty for intercept

    # solve (A^T A + alpha I) w = A^T x
    ATA = A.T @ A
    rhs = A.T @ xt
    w = np.linalg.solve(ATA + alpha * I, rhs)
    xhat = A @ w
    resid = xt - xhat
    return resid.astype(np.float32), xhat.astype(np.float32)

def permute_conditional_delta_rmse(model, Xtest, ytest, j, alpha=1.0, repeats=3, seed=0):
    """
    Conditional (residual) permutation:
      x_j = xhat(others) + resid
      permute resid, keep xhat fixed => preserves correlation structure with others
    """
    rng = np.random.default_rng(seed)
    # build others
    others = [k for k in range(Xtest.shape[1]) if k != j]
    Xo = Xtest[:, others]
    xj = Xtest[:, j]

    resid, xhat = ridge_fit_residual(Xo, xj, alpha=alpha)

    deltas = []
    for r in range(repeats):
        Xp = Xtest.copy()
        rp = resid.copy()
        rng.shuffle(rp)
        Xp[:, j] = xhat + rp
        p = model.predict(Xp)
        rmse = mean_squared_error(ytest, p) ** 0.5
        deltas.append(rmse - rmse0)

    return float(np.mean(deltas)), float(np.std(deltas))

