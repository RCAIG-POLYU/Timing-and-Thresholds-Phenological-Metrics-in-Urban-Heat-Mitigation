unique_cities = np.unique(groups_city)
print(f"Unique city groups: {len(unique_cities)} | CV folds: {N_SPLITS}")
print("Run dir:", run_dir)

for fold, (tr_idx, te_idx) in enumerate(gkf.split(X, y, groups=groups_city), start=1):
    X_tr, y_tr = X[tr_idx], y[tr_idx]
    X_te, y_te = X[te_idx], y[te_idx]

    train_groups = np.unique(groups_city[tr_idx]).size
    test_groups  = np.unique(groups_city[te_idx]).size

    print(f"\n[Fold {fold}/{N_SPLITS}] train={X_tr.shape} test={X_te.shape} (groups train/test={train_groups}/{test_groups})")

    model, used_gpu = try_train_catboost(X_tr, y_tr, X_te, y_te, features)
    fold_used_gpu.append(bool(used_gpu))

    pred = model.predict(X_te)
    met = eval_metrics(y_te, pred)
    met.update({"fold": fold, "train_groups": int(train_groups), "test_groups": int(test_groups),
                "n_train": int(X_tr.shape[0]), "n_test": int(X_te.shape[0]), "used_gpu": bool(used_gpu)})
    fold_metrics.append(met)
    print(f"[Fold {fold}] RMSE={met['rmse']:.3f}  MAE={met['mae']:.3f}  R2={met['r2']:.3f} | GPU={used_gpu}")

    # SHAP on test subset
    mean_abs, n_used = fast_shap_mean_abs(
        model, X_te, features,
        max_samples=SHAP_MAX_SAMPLES_PER_FOLD,
        seed=RANDOM_SEED + fold
    )
    fold_shap.append(mean_abs)

    top_idx = np.argsort(-mean_abs)[:SHAP_TOPK]
    top_names = [features[i] for i in top_idx]
    fold_topk.append(top_names)

    print(f"[Fold {fold}] SHAP computed on n={n_used:,} test samples. Top1={top_names[0]}")

    # save per-fold artifacts
    np.save(os.path.join(run_dir, f"fold{fold:02d}_shap_meanabs.npy"), mean_abs)
    with open(os.path.join(run_dir, f"fold{fold:02d}_top{SHAP_TOPK}.json"), "w") as f:
        json.dump({"fold": fold, "top_features": top_names}, f, indent=2)

