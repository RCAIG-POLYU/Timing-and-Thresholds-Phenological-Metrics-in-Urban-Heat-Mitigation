# 4) AGGREGATE STABILITY
# --------------------------
fold_metrics_df = pd.DataFrame(fold_metrics)
fold_metrics_df.to_csv(os.path.join(run_dir, "cv_metrics.csv"), index=False)

S = np.vstack(fold_shap)  # (Kfold, p)
mean_imp = S.mean(axis=0)
