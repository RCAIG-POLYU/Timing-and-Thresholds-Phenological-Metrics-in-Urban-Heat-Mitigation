def list_cities(root):
    return sorted([d for d in os.listdir(root) if os.path.isdir(os.path.join(root, d))])

def find_years_in_city(cdir):
    years = []
    for fn in os.listdir(cdir):
        fnl = fn.lower()
        if fnl.endswith(".tif") and ("_evi_8day_0p1deg_" in fnl or "_lst_8day_0p1deg_" in fnl or "_lstd_8day_0p1deg_" in fnl):
            m = year_re.match(fn)
            if m:
                years.append(int(m.group(1)))
    return sorted(list(set(years)))

def pick_years(years, k):
    if len(years) <= k:
        return years
    idx = rng.choice(len(years), size=k, replace=False)
    return [years[i] for i in sorted(idx)]

def p_city_var_year(city, var, year):
    """
    var: DEM/EVI/LAI/LST/ERA5LMAIN/NTL/LC
    """
    if var == "LC":
        return os.path.join(ROOT, city, f"{city}_MODIS_LC_STACK_2013_2025_0p005deg.tif")
    if var == "NTL":
        return os.path.join(ROOT, city, f"{city}_NTL_monthly_0p1deg_{year}.tif")
    if var == "ERA5LMAIN":
        return os.path.join(ROOT, city, f"{city}_ERA5Lmain_8day_0p1deg_{year}.tif")
    return os.path.join(ROOT, city, f"{city}_{var}_8day_0p1deg_{year}.tif")

def out_hw(H, W, factor):
    return int(math.ceil(H / factor)), int(math.ceil(W / factor))

def robust_summary(vecs_2d):
    """
    vecs_2d: (n_series, T)
    return mean, p10, p90
    """
    mean = np.nanmean(vecs_2d, axis=0)
    p10  = np.nanpercentile(vecs_2d, 10, axis=0)
    p90  = np.nanpercentile(vecs_2d, 90, axis=0)
    return mean, p10, p90

def monthly12_to_46(x12):
    x12 = np.asarray(x12, float)
    t12 = np.linspace(0, T8-1, num=12)
    t46 = np.arange(T8)
    return np.interp(t46, t12, x12)

# ----------------------
# fast read: bulk bands + coarse resample
# ----------------------
def read_coarse_allbands(path, band_ids=None, factor=10):
    """
    return data: (B, oh, ow) float32 with nan
    """
    with rasterio.open(path) as ds:
        H, W = ds.height, ds.width
        oh, ow = out_hw(H, W, factor)
        if band_ids is None:
            band_ids = list(range(1, ds.count+1))
        data = ds.read(
            indexes=band_ids,
            masked=True,
            out_shape=(len(band_ids), oh, ow),
            resampling=Resampling.average
        ).astype(np.float32)
        if np.ma.isMaskedArray(data):
            data = data.filled(np.nan)
        return data  # (B,oh,ow)

def median_over_grid(data_bhw):
    """
    data_bhw: (B,H,W)
    return med per band: (B,)
    """
    B = data_bhw.shape[0]
    flat = data_bhw.reshape(B, -1)
    med = np.nanmedian(flat, axis=1)
    return med

# ----------------------
# extract one city-year seasonal curves (fast)
# ----------------------
def extract_city_year_fast(city, year):

    out = {}

    # ---------------------------
    # 8-day variables
    # ---------------------------
    for var in ["EVI","LAI","LST","DEM"]:

        p = p_city_var_year(city, var, year)
        if not os.path.exists(p):
            continue

        with rasterio.open(p) as ds:

            band_count = ds.count
            H,W = ds.height,ds.width

            oh,ow = out_hw(H,W,COARSE_FACTOR)

            data = ds.read(
                masked=True,
                out_shape=(band_count,oh,ow),
                resampling=Resampling.average
            )

            data = data.astype(np.float32)

            if np.ma.isMaskedArray(data):
                data = data.filled(np.nan)

            med = np.nanmedian(data.reshape(band_count,-1),axis=1)

            y = np.full(T8,np.nan)

            n = min(T8,band_count)

            y[:n] = med[:n]

            out[var] = y


    # ---------------------------
    # ERA5Lmain
    # ---------------------------

    p = p_city_var_year(city,"ERA5LMAIN",year)

    if os.path.exists(p):

        with rasterio.open(p) as ds:

            band_count = ds.count
            H,W = ds.height,ds.width

            oh,ow = out_hw(H,W,COARSE_FACTOR)

            data = ds.read(
                masked=True,
                out_shape=(band_count,oh,ow),
                resampling=Resampling.average
            )

            data = data.astype(np.float32)

            if np.ma.isMaskedArray(data):
                data = data.filled(np.nan)

            med = np.nanmedian(data.reshape(band_count,-1),axis=1)

            nstep = band_count // 8

            for j,var in enumerate(ERA5_SUBVARS):

                y = np.full(T8,np.nan)

                for s in range(min(nstep,T8)):

                    idx = s*8 + j

                    if idx < band_count:

                        y[s] = med[idx]

                out[f"ERA5_{var}"] = y


    # ---------------------------
    # NTL
    # ---------------------------

    if USE_NTL:

        p = p_city_var_year(city,"NTL",year)

        if os.path.exists(p):

            with rasterio.open(p) as ds:

                band_count = min(ds.count,12)

                H,W = ds.height,ds.width

                oh,ow = out_hw(H,W,COARSE_FACTOR)

                data = ds.read(
                    masked=True,
                    out_shape=(band_count,oh,ow),
                    resampling=Resampling.average
                )

                data = data.astype(np.float32)

                if np.ma.isMaskedArray(data):
                    data = data.filled(np.nan)

                med = np.nanmedian(data.reshape(band_count,-1),axis=1)

                if np.isfinite(med).sum()>=6:

                    out["NTL"] = monthly12_to_46(med)

    return out

# ======================
