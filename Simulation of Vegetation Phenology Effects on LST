# ============================================================
# 2) Small utilities
# ============================================================
def _infer_cols(df):
    cols = set(df.columns.str.lower())
    is_long = ("clim_major" in cols) and (("var" in cols) or ("variable" in cols))
    return "long" if is_long else "wide"

def _resample_to_T(x, T=46):
    x = np.asarray(x, dtype=float)
    n = len(x)
    if n == T:
        return x.copy()
    if n < 2:
        return np.full(T, np.nan)
    t0 = np.linspace(0, 1, n)
    t1 = np.linspace(0, 1, T)
    return np.interp(t1, t0, x)

def stable_seed(key, mc, base_seed=42):
    s = str(key)
    h = 2166136261
    for ch in s:
        h ^= ord(ch)
        h = (h * 16777619) & 0xFFFFFFFF
    return (base_seed + (h % 100000) * 1000 + mc) % (2**32 - 1)

def doys_from_steps(T=46, dt_days=8.0):
    return np.arange(T) * dt_days + dt_days/2.0

def circular_diff(a, b, period=365.0):
    d = (a - b) % period
    if d > period/2:
        d -= period
    return d

def ar1_noise(T, sigma, rho=0.9, rng=None):
    rng = np.random.default_rng() if rng is None else rng
    if (not np.isfinite(sigma)) or sigma <= 0:
        return np.zeros(T, dtype=float)
    eps = rng.normal(0, 1, size=T)
    x = np.zeros(T, dtype=float)
    x[0] = rng.normal(0, sigma)
    innov = sigma * np.sqrt(max(1e-8, 1 - rho**2))
    for t in range(1, T):
        x[t] = rho * x[t-1] + innov * eps[t]
    return x

def winsorize(arr, qlo=2.5, qhi=97.5):
    arr = np.asarray(arr, dtype=float)
    lo = np.nanpercentile(arr, qlo)
    hi = np.nanpercentile(arr, qhi)
    return np.clip(arr, lo, hi)


# ============================================================
# 3) Robust peak metrics
# ============================================================
def robust_peak_value(x, mode="topk", topk=3, pctl=99):
    x = np.asarray(x, float)
    m = np.isfinite(x)
    if m.sum() == 0:
        return np.nan
    xv = x[m]
    if mode == "pctl":
        return float(np.nanpercentile(xv, pctl))
    k = int(max(1, min(topk, len(xv))))
    idx = np.argsort(xv)[-k:]
    return float(np.nanmean(xv[idx]))

def robust_peak_time_doy(x, dt_days=8.0, mode="topk", topk=3, pctl=99):
    x = np.asarray(x, float)
    doys = doys_from_steps(len(x), dt_days)
    m = np.isfinite(x)
    if m.sum() == 0:
        return np.nan
    xv = x[m]
    dv = doys[m]
    if mode == "pctl":
        thr = np.nanpercentile(xv, pctl)
        sel = xv >= thr
        if sel.sum() >= 2:
            return float(np.nanmean(dv[sel]))
    k = int(max(1, min(topk, len(xv))))
    idx = np.argsort(xv)[-k:]
    return float(np.nanmean(dv[idx]))

def compute_metrics(lst_series, warm_doy=WARM_DOY, dt_days=8.0):
    x = np.asarray(lst_series, dtype=float)
    doys = doys_from_steps(len(x), dt_days)

    peak_time = robust_peak_time_doy(
        x, dt_days=dt_days,
        mode=ROBUST_PEAK_MODE, topk=ROBUST_TOPK, pctl=ROBUST_PCTL
    )
    peak_val = robust_peak_value(
        x, mode=ROBUST_PEAK_MODE, topk=ROBUST_TOPK, pctl=ROBUST_PCTL
    )

    m = (doys >= warm_doy[0]) & (doys <= warm_doy[1])
    xw = x[m]
    warm_mean = float(np.nanmean(xw))
    warm_p90  = float(np.nanpercentile(xw, 90))
    warm_p95  = float(np.nanpercentile(xw, 95))

    thr = float(np.nanmedian(xw))
    excess = np.maximum(0, xw - thr)
    heat_expo = float(np.nansum(excess) * dt_days)

    return dict(
        peak_time_doy=peak_time,
        peak_value=peak_val,
        warm_mean=warm_mean,
        warm_p90=warm_p90,
        warm_p95=warm_p95,
        heat_expo=heat_expo
    )


# ============================================================
# 4) Counterfactual operator: advance within a window (no-wrap + blend)
# ============================================================
def shift_within_window_no_wrap(x_seg, advance_days, dt_days=8.0):
    x_seg = np.asarray(x_seg, dtype=float)
    L = len(x_seg)
    if L <= 1 or advance_days <= 0:
        return x_seg.copy()

    s = advance_days / dt_days
    k = np.arange(L, dtype=float)
    src = np.clip(k + s, 0, L - 1)

    i0 = np.floor(src).astype(int)
    i1 = np.clip(i0 + 1, 0, L - 1)
    w = src - i0
    return (1 - w) * x_seg[i0] + w * x_seg[i1]

def greenup_advance(x, advance_days, window_doy=(60, 180), dt_days=8.0, blend_steps=2):
    x = np.asarray(x, dtype=float)
    Tloc = len(x)
    if advance_days <= 0:
        return x.copy()

    doys = doys_from_steps(Tloc, dt_days)
    m = (doys >= window_doy[0]) & (doys <= window_doy[1])
    idx = np.where(m)[0]
    if len(idx) < 3:
        return x.copy()

    i0, i1 = int(idx[0]), int(idx[-1])
    seg = x[i0:i1+1]
    seg_shift = shift_within_window_no_wrap(seg, advance_days, dt_days=dt_days)

    y = x.copy()
    y[i0:i1+1] = seg_shift

    b = int(max(0, blend_steps))
    if b > 0:
        l0 = max(0, i0 - b)
        for t in range(l0, i0):
            w = (t - l0 + 1) / (i0 - l0 + 1)
            y[t] = (1 - w) * x[t] + w * y[t]

        r1 = min(Tloc - 1, i1 + b)
        for t in range(i1 + 1, r1 + 1):
            w = (r1 - t + 1) / (r1 - (i1 + 1) + 1)
            y[t] = (1 - w) * x[t] + w * y[t]

    return y


# ============================================================
# 5) Placebo-OPT: random-window placebo (same length as spring window)
# ============================================================
def window_mask_from_doy(T, dt_days, window_doy):
    doys = doys_from_steps(T, dt_days)
    m = (doys >= window_doy[0]) & (doys <= window_doy[1])
    idx = np.where(m)[0]
    if len(idx) == 0:
        return None
    return int(idx[0]), int(idx[-1])

def random_window_same_length(rng, ref_window_doy=(60, 180), T=46, dt_days=8.0):
    ref = window_mask_from_doy(T, dt_days, ref_window_doy)
    if ref is None:
        return ref_window_doy

    i0, i1 = ref
    L = i1 - i0 + 1

    s0 = int(rng.integers(0, max(1, T - L + 1)))
    s1 = s0 + L - 1

    doys = doys_from_steps(T, dt_days)
    doy_start = float(doys[s0] - dt_days/2.0)
    doy_end   = float(doys[s1] + dt_days/2.0)
    return (doy_start, doy_end)

def build_X1_main(X0, d, feat2idx):
    X1 = X0.copy()
    for ch in SHIFT_VARS_MODEL:
        if ch in feat2idx:
            j = feat2idx[ch]
            X1[:, j] = greenup_advance(
                X1[:, j], advance_days=d,
                window_doy=GREENUP_DOY,
                dt_days=DT_DAYS, blend_steps=BLEND_STEPS
            ).astype(np.float32)
    return X1

def build_X1_placebo_randomwindow(X0, d, feat2idx, rng):
    X1 = X0.copy()
    placebo_win = random_window_same_length(
        rng, ref_window_doy=GREENUP_DOY, T=X0.shape[0], dt_days=DT_DAYS
    )
    for ch in SHIFT_VARS_MODEL:
        if ch in feat2idx:
            j = feat2idx[ch]
            X1[:, j] = greenup_advance(
                X1[:, j], advance_days=d,
                window_doy=placebo_win,
                dt_days=DT_DAYS, blend_steps=BLEND_STEPS
            ).astype(np.float32)
    return X1


