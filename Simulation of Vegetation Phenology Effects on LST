def predict_lst_series(X_ts):
    return model.predict(X_ts).astype(np.float32)

def gen_one_ts_for_clim(clim, rng, AR1_RHO=0.90, NOISE_SCALE=0.55, CLIP_TO_P_BOUNDS=True):
    X = np.zeros((T, len(channels)), dtype=np.float32)
    for j, ch in enumerate(channels):
        if (clim in lib) and (ch in lib[clim]):
            mu  = lib[clim][ch]["mu"]
            sg  = lib[clim][ch]["sigma"]
            plo = lib[clim][ch]["plo"]
            phi = lib[clim][ch]["phi"]

            mult = NOISE_MULT.get(ch, DEFAULT_NOISE_MULT)
            sigma0 = float(np.nanmedian(sg)) * float(NOISE_SCALE) * float(mult)

            x = mu + ar1_noise(T, sigma=sigma0, rho=AR1_RHO, rng=rng)

            if CLIP_TO_P_BOUNDS:
                x = np.minimum(np.maximum(x, plo), phi)

            X[:, j] = x.astype(np.float32)
        else:
            X[:, j] = 0.0
    return X

def run_mc_global_setting(setting):
