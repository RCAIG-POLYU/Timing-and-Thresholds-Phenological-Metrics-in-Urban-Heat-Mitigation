def weighted_quantile(values, quantiles, sample_weight=None):
    values = np.asarray(values, dtype=float)
    quantiles = np.asarray(quantiles, dtype=float)
    if sample_weight is None:
        return np.quantile(values, quantiles)

    w = np.asarray(sample_weight, dtype=float)
    mask = np.isfinite(values) & np.isfinite(w)
    values = values[mask]
    w = w[mask]
    if len(values) == 0:
        return np.full_like(quantiles, np.nan, dtype=float)

    sorter = np.argsort(values)
    values = values[sorter]
    w = w[sorter]
    cdf = np.cumsum(w) - 0.5*w
    cdf /= np.sum(w)
    return np.interp(quantiles, cdf, values)

def summarize_global_by_kind(df_all, ncity_by_clim, mode="equal"):
    metrics = ["d_peak_time","d_peak_lst","d_warm_mean","d_warm_p90","d_warm_p95","d_heat_expo"]
    out = []
    z = 1.96  # ~95%

    for (kind, d), g in df_all.groupby(["kind", "delta_days"]):
        if mode == "equal":
            w = np.ones(len(g), dtype=float)
        else:
            w = g["clim"].map(lambda c: max(1.0, float(ncity_by_clim.get(c, 1)))).values

        row = {"kind": kind, "clim": "GLOBAL", "delta_days": int(d), "n": int(len(g))}

        for m in metrics:
            vals = g[m].values.astype(float)

            if CI_MODE == "percentile" and WINSORIZE:
                vals = winsorize(vals, WINSOR_Q_LO, WINSOR_Q_HI)

            mean = float(np.average(vals, weights=w))
            row[m+"_mean"] = mean

            if CI_MODE == "sem":
                var = float(np.average((vals - mean)**2, weights=w))
                std = np.sqrt(max(1e-12, var))
                sem = std / np.sqrt(len(vals))
                row[m+"_lo"] = mean - z * sem
                row[m+"_hi"] = mean + z * sem
            else:
                qlo = CI_ALPHA/2
                qhi = 1 - CI_ALPHA/2
                lo, hi = weighted_quantile(vals, [qlo, qhi], sample_weight=w)
                row[m+"_lo"] = float(lo)
                row[m+"_hi"] = float(hi)

        out.append(row)

    return pd.DataFrame(out).sort_values(["kind","delta_days"]).reset_index(drop=True)

